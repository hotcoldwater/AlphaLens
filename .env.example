OPENAI_API_KEY=
# FMP NASDAQ/US daily OHLCV data. Keep this file secret and never commit .env.
FMP_API_KEY=
# KRX Open API authentication key. Set this after the KRX application is approved.
KRX_API_KEY=
# PostgreSQL URL for Neon or another managed Postgres service. Use the pooled URL in Render.
DATABASE_URL=
# Comma-separated deployed frontend origins, for example https://alphalens.pages.dev
ALPHALENS_ALLOWED_ORIGINS=
# Override for a persistent deployment volume, for example /var/data/market_data.
ALPHALENS_MARKET_DATA_PATH=data/market_data
OPENAI_MODEL=gpt-5.6
